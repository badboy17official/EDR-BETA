POSTGRES_USER=threatuser
POSTGRES_PASSWORD=threatpass
POSTGRES_DB=threatdb

DATABASE_URL=postgresql+asyncpg://threatuser:threatpass@postgres:5432/threatdb
REDIS_URL=redis://redis:6379/0
